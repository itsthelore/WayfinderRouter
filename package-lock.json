{
  "name": "wayfinder-clients",
  "version": "0.0.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "wayfinder-clients",
      "version": "0.0.0",
      "workspaces": [
        "clients/shared",
        "clients/desktop"
      ]
    },
    "clients/desktop": {
      "name": "@wayfinder/desktop",
      "version": "0.1.0",
      "dependencies": {
        "@wayfinder/shared": "*"
      }
    },
    "clients/shared": {
      "name": "@wayfinder/shared",
      "version": "0.0.0"
    },
    "node_modules/@wayfinder/desktop": {
      "resolved": "clients/desktop",
      "link": true
    },
    "node_modules/@wayfinder/shared": {
      "resolved": "clients/shared",
      "link": true
    }
  }
}
